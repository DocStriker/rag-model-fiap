# =====================================================================
# Variáveis de ambiente — copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =====================================================================

# --- Anthropic (LLM) -------------------------------------------------
# Obtenha em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Embeddings) ---------------------------------------------
# Obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Qdrant ----------------------------------------------------------
# Cluster gerenciado: https://cloud.qdrant.io
# Local (Docker): http://localhost:6333
QDRANT_ENDPOINT=https://<seu-cluster>.qdrant.io
QDRANT_API_KEY=

# --- Configurações opcionais -----------------------------------------
# Formato de log: "console" (desenvolvimento) | "json" (produção)
LOG_FORMAT=console

# Origens permitidas no CORS (separadas por vírgula, ou * para todas)
CORS_ORIGINS=*
